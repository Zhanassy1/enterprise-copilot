# Python
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
*.pyo
*.pyd
.venv/
venv/

# Local Python install / venv layout under backend (Windows py -m venv or manual)
backend/Lib/
backend/Include/
# On case-insensitive FS, ``Scripts`` (venv) can hide ``scripts/`` — un-ignore, then add only
# the CLI ``*.py`` you want (or use ``git add -f path``). Put local venv under ``.venv/`` instead.
backend/Scripts/
!backend/scripts/
backend/share/

# Environment
.env
.env.local

# FastAPI / local files
*.log

# TypeScript incremental cache
*.tsbuildinfo

# Node.js
node_modules/
dist/
build/
frontend/.next/
frontend/test-results/
frontend/playwright-report/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Celery Beat local schedule DB (machine-specific)
**/celerybeat-schedule

# Runtime data
backend/data/uploads/

# Local retrieval eval datasets (may contain PII or production snippets — never commit)
backend/eval/*_local.jsonl
backend/eval/*_private.jsonl
backend/eval/*_private.*
