# Dev template: copy to `backend/.env` for local `uvicorn` / pytest, or merge with Docker env.
# Do not commit real secrets. Production: see `/.env.production.example` in repo root.

ENVIRONMENT=local
SECRET_KEY=change-me-use-long-random-string-min-32-chars

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/enterprise_copilot
REDIS_URL=redis://localhost:6380/0

STORAGE_BACKEND=local
INGESTION_ASYNC_ENABLED=1
# ALLOW_SYNC_INGESTION_FOR_DEV=0

LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1

# Optional: Sentry, proxy (see docs/security.md)
# SENTRY_DSN=
# USE_FORWARDED_HEADERS=0
# TRUSTED_PROXY_IPS=
