# Committed defaults for `docker compose` (env_file must exist). Not for production secrets.
# docker-compose.yml overrides DATABASE_URL/REDIS_URL/INGESTION_ASYNC_ENABLED for containers.

ENVIRONMENT=local
SECRET_KEY=dev-secret-change-me

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/enterprise_copilot
REDIS_URL=redis://localhost:6379/0

STORAGE_BACKEND=local
# Overridden in docker-compose.yml to 1 for api/worker
INGESTION_ASYNC_ENABLED=0

LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1

# Платформенная админка /admin: email(ы) через запятую (локальная копия — свой адрес, не коммитить в git).
# PLATFORM_ADMIN_EMAILS=you@example.com
