# Copy to .env and fill in values. Do not commit .env with production secrets.
# Prefer a secrets manager (AWS Secrets Manager, Vault, etc.) in deployed environments.

ENVIRONMENT=local
SECRET_KEY=change-me-use-long-random-string

# Require X-Workspace-Id in all envs (staging parity with prod).
# REQUIRE_WORKSPACE_HEADER_STRICT=false

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@localhost:5432/enterprise_copilot
REDIS_URL=redis://localhost:6379/0

# Resource limits (see docs/deployment.md)
# MAX_UPLOAD_BYTES_PER_FILE=26214400
# MAX_CONCURRENT_INGESTION_JOBS_PER_WORKSPACE=5
# MAX_RERANK_CALLS_PER_WORKSPACE_MONTH=100000
# MAX_PDF_PAGES_PROCESSED_PER_WORKSPACE_MONTH=500000
# RATE_LIMIT_PER_WORKSPACE_PER_MINUTE=600

# Observability
# OBSERVABILITY_JSON_LOGS=false
# OBSERVABILITY_SENTRY_WORKSPACE_TAG=true

# Optional: separate Celery broker/backend (defaults to REDIS_URL)
# CELERY_BROKER_URL=
# CELERY_RESULT_BACKEND_URL=

# Storage: local | s3
STORAGE_BACKEND=local
# S3_ENDPOINT_URL=
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=

# LLM (OpenAI-compatible)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1

# Async ingestion (set INGESTION_ASYNC_ENABLED=1 for worker-based pipeline)
INGESTION_ASYNC_ENABLED=0

# Observability
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.0
