# Copy to .env and fill in values. Do not commit .env with production secrets.
# Prefer a secrets manager (AWS Secrets Manager, Vault, etc.) in deployed environments.
# Production template (placeholders only): ../../.env.production.example

ENVIRONMENT=local
SECRET_KEY=change-me-use-long-random-string

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@localhost:5432/enterprise_copilot
REDIS_URL=redis://localhost:6379/0

# Reverse proxy (optional): only if behind nginx/ingress — set TRUSTED_PROXY_IPS when USE_FORWARDED_HEADERS=1
# USE_FORWARDED_HEADERS=0
# TRUSTED_PROXY_IPS=

# Optional: separate Celery broker/backend (defaults to REDIS_URL)
# CELERY_BROKER_URL=
# CELERY_RESULT_BACKEND_URL=

# Storage: local | s3
STORAGE_BACKEND=local
# S3_ENDPOINT_URL=
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=

# LLM (OpenAI-compatible)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1

# Async ingestion (recommended): 1 + Celery worker. For local dev without worker: 0 and ALLOW_SYNC_INGESTION_FOR_DEV=1
INGESTION_ASYNC_ENABLED=1
# ALLOW_SYNC_INGESTION_FOR_DEV=0

# Rate limits (HTTP middleware; часть лимитов масштабируется по плану workspace — см. docs/quotas.md)
# RATE_LIMIT_PER_USER_PER_MINUTE=120
# RATE_LIMIT_PER_IP_PER_MINUTE=240
# RATE_LIMIT_RAG_PER_USER_PER_MINUTE=60
# RATE_LIMIT_AUTH_PER_IP_PER_MINUTE=30
# RATE_LIMIT_UPLOAD_PER_USER_PER_MINUTE=30

# Observability
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.0
