# Example environment for: docker compose -f docker-compose.yml -f docker-compose.prod.yml
# Copy to .env in the project root (gitignored) or pass via CI secrets.
# Passwords must be URL-safe or percent-encoded in DATABASE_URL / REDIS_URL.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-long-random
POSTGRES_DB=enterprise_copilot

REDIS_PASSWORD=change-me-another-long-random

# psycopg3 URL — password must match POSTGRES_PASSWORD
DATABASE_URL=postgresql+psycopg://postgres:change-me-long-random@db:5432/enterprise_copilot

# Redis URL — password must match REDIS_PASSWORD (note leading colon before @)
REDIS_URL=redis://:change-me-another-long-random@redis:6379/0

ENVIRONMENT=production
SECRET_KEY=change-me-use-openssl-rand-hex-32

# Optional: override Celery broker if not same as REDIS_URL
# CELERY_BROKER_URL=
# CELERY_RESULT_BACKEND_URL=
